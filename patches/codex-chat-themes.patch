+use std::env;
+use std::sync::OnceLock;
+
+#[derive(Clone, Copy, Debug, Eq, PartialEq)]
+pub enum UserMessageTheme {
+    Box,
+    BoxClean,
+    Flat,
+    Slate,
+}
+
+impl UserMessageTheme {
+    fn parse(value: &str) -> Self {
+        match value.trim().to_ascii_lowercase().as_str() {
+            "box-clean" | "boxclean" | "clean" => Self::BoxClean,
+            "flat" => Self::Flat,
+            "slate" => Self::Slate,
+            _ => Self::Box,
+        }
+    }
+
+    pub fn uses_box(self) -> bool {
+        matches!(self, Self::Box | Self::BoxClean)
+    }
+
+    pub fn label(self) -> Option<&'static str> {
+        match self {
+            Self::Box => Some(" You "),
+            Self::BoxClean | Self::Flat | Self::Slate => None,
+        }
+    }
+
+    fn user_fg(self) -> Color {
+        Color::Rgb(239, 240, 235)
+    }
+
+    fn user_bg(self) -> Color {
+        match self {
+            Self::Box => Color::Rgb(43, 54, 65),
+            Self::BoxClean => Color::Rgb(37, 47, 58),
+            Self::Flat => Color::Rgb(57, 80, 96),
+            Self::Slate => Color::Rgb(50, 61, 72),
+        }
+    }
+
+    fn border_fg(self) -> Color {
+        match self {
+            Self::Box => Color::Rgb(104, 192, 204),
+            Self::BoxClean => Color::Rgb(137, 156, 173),
+            Self::Flat => self.user_bg(),
+            Self::Slate => self.user_bg(),
+        }
+    }
+}
+
+pub fn user_message_theme() -> UserMessageTheme {
+    static THEME: OnceLock<UserMessageTheme> = OnceLock::new();
+    *THEME.get_or_init(|| {
+        env::var("CODEX_CHAT_THEME")
+            .ok()
+            .map(|value| UserMessageTheme::parse(&value))
+            .unwrap_or(UserMessageTheme::Box)
+    })
+}
 
 pub fn user_message_style() -> Style {
     user_message_style_for(default_bg())
 }
 
+pub fn user_message_border_style() -> Style {
+    let theme = user_message_theme();
+    Style::default()
+        .fg(theme.border_fg())
+        .bg(theme.user_bg())
