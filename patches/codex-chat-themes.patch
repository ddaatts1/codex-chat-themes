+const USER_BOX_MIN_WIDTH: u16 = 12;
+const USER_BOX_HORIZONTAL_CHROME: u16 = 4;
+const USER_BAR_MIN_WIDTH: u16 = 8;
+const USER_BAR_PREFIX_WIDTH: u16 = 2;
+
+fn pad_line_to_width(mut line: Line<'static>, target_width: usize, style: Style) -> Line<'static> {
+    let pad = target_width.saturating_sub(line.width());
+    if pad > 0 {
+        line.spans.push(Span::styled(" ".repeat(pad), style));
+    }
+    line.style = style;
+    line
+}
+
+fn user_box_rule(
+    left: &str,
+    right: &str,
+    middle_width: usize,
+    style: Style,
+    title: Option<&str>,
+) -> Line<'static> {
+    let mut spans = vec![Span::styled(left.to_string(), style)];
+
+    if let Some(title) = title {
+        let title_width = title.width();
+        if title_width < middle_width {
+            spans.push(Span::styled("─".to_string(), style));
+            spans.push(Span::styled(title.to_string(), style));
+            spans.push(Span::styled(
+                "─".repeat(middle_width.saturating_sub(title_width + 1)),
+                style,
+            ));
+        } else {
+            spans.push(Span::styled("─".repeat(middle_width), style));
+        }
+    } else {
+        spans.push(Span::styled("─".repeat(middle_width), style));
+    }
+
+    spans.push(Span::styled(right.to_string(), style));
+    Line::from(spans).style(style)
+}
+
+fn render_user_box(
+    content_lines: Vec<Line<'static>>,
+    width: u16,
+    style: Style,
+    border_style: Style,
+    title: Option<&str>,
+) -> Vec<Line<'static>> {
+    if width < USER_BOX_MIN_WIDTH {
+        return content_lines;
+    }
+
+    let inner_width = usize::from(width.saturating_sub(USER_BOX_HORIZONTAL_CHROME).max(1));
+    let mut lines = Vec::with_capacity(content_lines.len() + 4);
+    lines.push(Line::from("").style(style));
+    lines.push(user_box_rule("╭", "╮", inner_width + 2, border_style, title));
+
+    for line in content_lines {
+        let padded = pad_line_to_width(line, inner_width, style);
+        let mut spans = Vec::with_capacity(padded.spans.len() + 2);
+        spans.push(Span::styled("│ ".to_string(), border_style));
+        spans.extend(padded.spans);
+        spans.push(Span::styled(" │".to_string(), border_style));
+        lines.push(Line::from(spans).style(style));
+    }
+
+    lines.push(user_box_rule("╰", "╯", inner_width + 2, border_style, None));
+    lines.push(Line::from("").style(style));
+    lines
+}
+
+fn render_user_bar(content_lines: Vec<Line<'static>>, width: u16, style: Style) -> Vec<Line<'static>> {
+    if width < USER_BAR_MIN_WIDTH {
+        return content_lines;
+    }
+
+    let inner_width = usize::from(width.saturating_sub(USER_BAR_PREFIX_WIDTH).max(1));
+    let mut lines = Vec::with_capacity(content_lines.len() + 2);
+    lines.push(Line::from(""));
+
+    for (idx, line) in content_lines.into_iter().enumerate() {
+        let prefix = if idx == 0 { "› " } else { "  " };
+        let padded = pad_line_to_width(line, inner_width, style);
+        let mut spans = Vec::with_capacity(padded.spans.len() + 2);
+        spans.push(Span::styled(prefix.to_string(), style));
+        spans.extend(padded.spans);
+        lines.push(Line::from(spans).style(style));
+    }
+
+    lines.push(Line::from(""));
+    lines
+}
+
+fn render_user_message(
+    theme: UserMessageTheme,
+    content_lines: Vec<Line<'static>>,
+    width: u16,
+    style: Style,
+    border_style: Style,
+) -> Vec<Line<'static>> {
+    match theme {
+        UserMessageTheme::Box | UserMessageTheme::BoxClean => {
+            render_user_box(content_lines, width, style, border_style, theme.label())
+        }
+        UserMessageTheme::Flat | UserMessageTheme::Slate => render_user_bar(content_lines, width, style),
+    }
+}
